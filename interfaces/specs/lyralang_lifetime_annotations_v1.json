{
  "version": "1.0.0",
  "module": "lyralang::lifetimes",
  "task": "P1-013",
  "description": "Lifetime annotations and region inference checker for LyraLang Stage 0",
  "checker": {
    "struct": "LifetimeChecker",
    "constructor": "LifetimeChecker::new()",
    "method": "check_source(&str) -> LifetimeCheckOutput"
  },
  "free_function": "check(&str) -> LifetimeCheckOutput",
  "output_type": "LifetimeCheckOutput",
  "output_fields": {
    "normalized_source": "String",
    "judgment": "Option<LifetimeProgramJudgment>",
    "errors": "Vec<LifetimeError>"
  },
  "judgment_type": "LifetimeProgramJudgment",
  "judgment_fields": {
    "module": "Option<String>",
    "bindings": "Vec<LifetimeBindingJudgment>",
    "regions": "Vec<RegionConstraint>",
    "dangling_free": "bool",
    "elision_applied": "Vec<String>",
    "span": "SourceSpan"
  },
  "binding_judgment_type": "LifetimeBindingJudgment",
  "binding_judgment_fields": {
    "name": "String",
    "inferred_region": "String",
    "borrow_kind": "BorrowKind",
    "span": "SourceSpan"
  },
  "borrow_kinds": ["Owned", "SharedRef", "UniqueRef", "Static"],
  "region_constraint_type": "RegionConstraint",
  "region_constraint_fields": {
    "lhs": "String",
    "rhs": "String",
    "constraint": "OutlivesKind"
  },
  "outlives_kinds": ["Outlives", "SameScopeAs", "Static"],
  "error_type": "LifetimeError",
  "error_fields": {
    "kind": "LifetimeErrorKind",
    "message": "String",
    "span": "SourceSpan",
    "recovered": "bool"
  },
  "error_kinds": [
    "ParseError",
    "DanglingReference",
    "LifetimeTooShort",
    "ConflictingBorrows"
  ],
  "inference_rules": {
    "linear_resource": "BorrowKind::Owned, region='static",
    "string_literal": "BorrowKind::Static, region='static",
    "other": "BorrowKind::SharedRef, region=fresh('a,'b,...)",
    "dangling_free_guarantee": "always true in Stage 0 (no raw pointers)"
  },
  "elision_rule": "applied when exactly one SharedRef exists in scope at binding time"
}
